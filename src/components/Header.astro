---
const base = import.meta.env.BASE_URL;
---

<header class="site-header">
    <div class="container header-inner">
        <a href={base} class="brand" aria-label="Label Lab 홈">
            <span class="brand-name">Label Lab</span>
            <span class="brand-line">B2B Manufacturing</span>
        </a>
        <nav aria-label="주요 메뉴">
            <a href={`${base}#products`}>솔루션</a>
            <a href={`${base}details/print-label/`}>포트폴리오</a>
            <a href="#contact" class="nav-accent">상담 문의</a>
        </nav>
    </div>
</header>

<style>
    .site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        border-bottom: 1px solid rgba(0, 0, 0, 0.03);
        background: rgba(250, 250, 248, 0.88);
        backdrop-filter: blur(18px);
    }

    .header-inner {
        display: flex;
        min-height: 76px;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-md);
    }

    .brand {
        display: inline-flex;
        flex-direction: column;
        justify-content: center;
        min-width: 190px;
        white-space: nowrap;
        text-decoration: none;
    }

    .brand-name {
        color: var(--text-heading);
        font-size: 1.24rem;
        font-weight: 900;
        line-height: 1;
        letter-spacing: 0;
        white-space: nowrap;
    }

    .brand-line {
        margin-top: 5px;
        color: var(--color-primary);
        font-size: 0.72rem;
        font-weight: 900;
        line-height: 1;
        letter-spacing: 0;
        text-transform: uppercase;
        white-space: nowrap;
    }

    nav {
        display: flex;
        align-items: center;
        gap: 30px;
    }

    nav a {
        color: var(--text-body);
        font-size: 0.92rem;
        font-weight: 800;
        text-decoration: none;
    }

    nav a:hover,
    .nav-accent {
        color: var(--color-primary);
    }

    @media (max-width: 768px) {
        nav {
            display: none;
        }
        .brand-name {
            font-size: 1.12rem;
        }

        .brand-line {
            font-size: 0.66rem;
        }

        .brand {
            min-width: 160px;
        }
    }
</style>
