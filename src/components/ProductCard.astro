---
interface Props {
    title: string;
    eyebrow: string;
    desc: string;
    image: string;
    href?: string;
    featured?: boolean;
}

const { title, eyebrow, desc, image, href, featured = false } = Astro.props;
---

<article class:list={["bento-card", "reveal", featured && "bento-card-featured"]}>
    <div class="bento-image">
        <img src={image} alt={`${title} 제작 샘플`} loading="lazy" />
    </div>
    <div class="bento-content">
        <p class="eyebrow">{eyebrow}</p>
        <h3>{title}</h3>
        <p>{desc}</p>
    </div>
    {href && <a href={href} class="bento-link" aria-label={`${title} 자세히 보기`}>자세히 보기</a>}
</article>

<style>
    .bento-card {
        position: relative;
        min-height: 100%;
        display: flex;
        flex-direction: column;
        padding: 28px;
        border: 1px solid rgba(13, 27, 42, 0.07);
        border-radius: var(--radius-lg);
        background: rgba(255, 255, 255, 0.88);
        box-shadow: var(--shadow-soft);
        overflow: hidden;
        transition: var(--transition-premium);
        backdrop-filter: blur(14px);
    }

    .bento-card::before {
        position: absolute;
        inset: -1px;
        border-radius: inherit;
        background:
            radial-gradient(circle at 16% 0%, rgba(242, 201, 76, 0.22), transparent 28%),
            radial-gradient(circle at 86% 12%, rgba(217, 83, 15, 0.17), transparent 32%);
        content: "";
        opacity: 0;
        transition: var(--transition-premium);
        pointer-events: none;
    }

    .bento-card:hover {
        border-color: rgba(217, 83, 15, 0.24);
        transform: translateY(-8px);
        box-shadow: 0 28px 70px rgba(217, 83, 15, 0.13), 0 18px 46px rgba(13, 27, 42, 0.08);
    }

    .bento-card:hover::before {
        opacity: 1;
    }

    .bento-card-featured {
        grid-column: span 2;
        grid-row: span 2;
        background:
            linear-gradient(145deg, rgba(255, 255, 255, 0.95), rgba(255, 248, 236, 0.9)),
            var(--color-surface);
    }

    .bento-image {
        position: relative;
        min-height: 156px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 26px;
        overflow: hidden;
        border-radius: 22px;
        background:
            linear-gradient(145deg, rgba(13, 27, 42, 0.035), rgba(217, 83, 15, 0.04)),
            #f5f2eb;
    }

    .bento-card-featured .bento-image {
        min-height: 334px;
    }

    .bento-image img {
        width: 100%;
        height: 100%;
        max-height: 282px;
        object-fit: cover;
        transition: var(--transition-premium);
    }

    .bento-card:hover .bento-image img {
        transform: scale(1.055);
    }

    .bento-card-featured .bento-image img {
        max-height: 370px;
    }

    .bento-content {
        position: relative;
        z-index: 1;
        margin-top: auto;
    }

    .bento-content h3 {
        margin: 10px 0 0;
        color: var(--text-heading);
        font-size: 1.5rem;
        font-weight: 900;
        line-height: 1.24;
        word-break: keep-all;
    }

    .bento-card-featured .bento-content h3 {
        font-size: clamp(2.1rem, 3.8vw, 3rem);
    }

    .bento-content p:not(.eyebrow) {
        margin: 10px 0 0;
        color: var(--text-body);
        font-size: 0.96rem;
        word-break: keep-all;
    }

    .bento-link {
        position: relative;
        z-index: 1;
        display: inline-flex;
        width: fit-content;
        min-height: 46px;
        align-items: center;
        justify-content: center;
        margin-top: 22px;
        padding: 12px 18px;
        border-radius: 999px;
        background: var(--color-navy);
        color: #fff;
        font-size: 0.9rem;
        font-weight: 900;
        text-decoration: none;
        transition: var(--transition-premium);
    }

    .bento-link:hover {
        background: var(--color-primary);
        transform: translateY(-3px);
        box-shadow: var(--shadow-hover);
    }

    @media (max-width: 768px) {
        .bento-card-featured {
            grid-column: span 1;
            grid-row: span 1;
        }

        .bento-card,
        .bento-card-featured {
            padding: 22px;
        }

        .bento-card:hover {
            transform: translateY(-4px);
        }

        .bento-card-featured .bento-image {
            min-height: 220px;
        }
    }
</style>
