---
interface Props {
    title: string;
    eyebrow: string;
    desc: string;
    image: string;
    href?: string;
    featured?: boolean;
}

const { title, eyebrow, desc, image, href, featured = false } = Astro.props;
---

<article class:list={["bento-card", featured && "bento-card-featured"]}>
    <div class="bento-image">
        <img src={image} alt={`${title} 제작 샘플`} loading="lazy" />
    </div>
    <div class="bento-content">
        <p class="eyebrow">{eyebrow}</p>
        <h3>{title}</h3>
        <p>{desc}</p>
    </div>
    {href && <a href={href} class="bento-link" aria-label={`${title} 자세히 보기`}>자세히 보기</a>}
</article>

<style>
    .bento-card {
        min-height: 100%;
        display: flex;
        flex-direction: column;
        padding: var(--space-lg);
        border: 1px solid rgba(0, 0, 0, 0.03);
        border-radius: var(--radius-lg);
        background: var(--color-surface);
        box-shadow: var(--shadow-soft);
        overflow: hidden;
        transition: var(--transition-premium);
    }

    .bento-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-hover);
    }

    .bento-card-featured {
        grid-column: span 2;
        grid-row: span 2;
    }

    .bento-image {
        min-height: 150px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: var(--space-lg);
    }

    .bento-card-featured .bento-image {
        min-height: 330px;
    }

    .bento-image img {
        width: 100%;
        max-height: 280px;
        object-fit: contain;
        filter: drop-shadow(0 18px 26px rgba(0, 0, 0, 0.08));
        transition: var(--transition-premium);
    }

    .bento-card:hover .bento-image img {
        transform: scale(1.03);
    }

    .bento-card-featured .bento-image img {
        max-height: 360px;
    }

    .bento-content {
        margin-top: auto;
    }

    .bento-content h3 {
        margin: var(--space-sm) 0 0;
        color: var(--text-heading);
        font-size: 1.55rem;
        font-weight: 900;
        line-height: 1.2;
        word-break: keep-all;
    }

    .bento-card-featured .bento-content h3 {
        font-size: 3rem;
    }

    .bento-content p:not(.eyebrow) {
        margin: var(--space-sm) 0 0;
        color: var(--text-body);
        word-break: keep-all;
    }

    .bento-link {
        display: inline-flex;
        min-height: 48px;
        align-items: center;
        justify-content: center;
        margin-top: var(--space-lg);
        padding: 12px 18px;
        border-radius: var(--radius-md);
        background: var(--text-heading);
        color: #fff;
        font-weight: 900;
        text-decoration: none;
        transition: var(--transition-premium);
    }

    .bento-link:hover {
        background: var(--color-primary);
        transform: translateY(-4px);
        box-shadow: var(--shadow-hover);
    }

    @media (max-width: 768px) {
        .bento-card-featured {
            grid-column: span 1;
            grid-row: span 1;
        }

        .bento-card,
        .bento-card-featured {
            padding: 24px;
        }

        .bento-card-featured .bento-image {
            min-height: 220px;
        }

        .bento-card-featured .bento-content h3 {
            font-size: 2.25rem;
        }
    }
</style>
