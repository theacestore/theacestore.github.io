---
const sampleFormUrl = "https://naver.me/GqfJUJaH";
const kakaoUrl = "https://open.kakao.com/o/sx6KEqpi";
const base = import.meta.env.BASE_URL;
---

<section class="hero-section">
    <div class="hero-bg" aria-hidden="true">
        <span class="hero-grid-layer"></span>
        <span class="hero-shine"></span>
    </div>
    <div class="container hero-grid">
        <div class="hero-copy">
            <p class="eyebrow hero-kicker">Premium B2B Label Manufacturing</p>
            <h1 class="hero-title">브랜드 품질을 완성하는 산업용 라벨 제조 파트너</h1>
            <p class="hero-lead hero-fade-up">
                레이블랩은 라벨, 패키지 부자재, 바코드 롤 라벨, 기능성 다이컷 소재를
                샘플부터 양산까지 한 흐름으로 설계합니다. 제조 현장의 속도와 브랜드의
                완성도를 함께 맞추는 프리미엄 B2B 생산 파트너입니다.
            </p>
            <div class="hero-actions hero-fade-up">
                <a href={sampleFormUrl} target="_blank" rel="noopener" class="button button-primary">샘플 상담하기</a>
                <a href={kakaoUrl} target="_blank" rel="noopener" class="button button-secondary">카카오톡 문의</a>
                <a href={`${base}#products`} class="button button-ghost">제품 포트폴리오</a>
            </div>
            <dl class="hero-proof hero-fade-up">
                <div>
                    <dt>Custom Spec</dt>
                    <dd>브랜드별 소재, 규격, 후가공 맞춤 제안</dd>
                </div>
                <div>
                    <dt>Fast Sample</dt>
                    <dd>샘플 검토 후 양산 사양 빠른 확정</dd>
                </div>
                <div>
                    <dt>Stable Supply</dt>
                    <dd>반복 발주에 적합한 생산 관리 체계</dd>
                </div>
            </dl>
        </div>

        <div class="hero-visual" aria-label="레이블랩 생산 제품 이미지">
            <div class="hero-main-card hero-fade-up">
                <img src={`${base}images/cab_hermes_q.jpg`} alt="CAB 자동 부착 시스템" class="hero-main-image" />
                <div class="hero-main-caption">
                    <span>Automated Labeling</span>
                    <strong>CAB 기반 정밀 라벨 솔루션</strong>
                </div>
            </div>
            <article class="hero-float-card hero-float-top hero-fade-up">
                <img src={`${base}images/hologram_label.jpg`} alt="인쇄 라벨 샘플" />
                <span>Printed Label</span>
            </article>
            <article class="hero-float-card hero-float-bottom hero-fade-up">
                <img src={`${base}images/spigen_case_poro.jpeg`} alt="정밀 다이컷 부자재" />
                <span>Die-cut Materials</span>
            </article>
        </div>
    </div>
</section>

<style>
    .hero-section {
        position: relative;
        min-height: calc(100vh - 76px);
        padding: 86px 0 54px;
        overflow: hidden;
        background:
            radial-gradient(circle at 14% 8%, rgba(242, 201, 76, 0.22), transparent 27%),
            radial-gradient(circle at 86% 18%, rgba(217, 83, 15, 0.18), transparent 28%),
            linear-gradient(145deg, #fffdf8 0%, var(--color-bg) 43%, #eef3f6 100%);
        isolation: isolate;
    }

    .hero-bg,
    .hero-grid-layer,
    .hero-shine {
        position: absolute;
        inset: 0;
        pointer-events: none;
    }

    .hero-bg {
        z-index: -1;
    }

    .hero-grid-layer {
        background-image:
            linear-gradient(rgba(13, 27, 42, 0.055) 1px, transparent 1px),
            linear-gradient(90deg, rgba(13, 27, 42, 0.055) 1px, transparent 1px);
        background-size: 56px 56px;
        mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.52), transparent 72%);
    }

    .hero-shine {
        transform: skewX(-18deg) translateX(-24%);
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.72), transparent);
        animation: heroShine 9s ease-in-out infinite;
    }

    .hero-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.04fr) minmax(360px, 0.96fr);
        gap: clamp(32px, 5vw, 72px);
        align-items: center;
    }

    .hero-copy {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        padding-top: 12px;
    }

    .hero-copy h1 {
        max-width: 760px;
        margin: 18px 0 0;
        color: var(--color-navy);
        font-size: clamp(3rem, 6.3vw, 5.95rem);
        font-weight: 900;
        line-height: 1.02;
        letter-spacing: 0;
        word-break: keep-all;
    }

    .hero-kicker,
    .hero-title,
    .hero-fade-up {
        opacity: 0;
        transform: translateY(22px);
        animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .hero-title {
        animation-delay: 0.1s;
    }

    .hero-fade-up {
        animation-delay: 0.28s;
    }

    .hero-actions.hero-fade-up {
        animation-delay: 0.42s;
    }

    .hero-proof.hero-fade-up,
    .hero-float-bottom.hero-fade-up {
        animation-delay: 0.56s;
    }

    .hero-lead {
        max-width: 680px;
        margin: 24px 0 0;
        color: var(--text-body);
        font-size: 1.08rem;
        font-weight: 500;
        word-break: keep-all;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 30px;
    }

    .hero-proof {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        width: 100%;
        max-width: 720px;
        margin: 42px 0 0;
        padding: 0;
    }

    .hero-proof div {
        padding: 18px;
        border: 1px solid rgba(13, 27, 42, 0.08);
        border-radius: var(--radius-lg);
        background: rgba(255, 255, 255, 0.72);
        box-shadow: var(--shadow-soft);
        backdrop-filter: blur(18px);
    }

    .hero-proof dt {
        color: var(--color-navy);
        font-size: 0.98rem;
        font-weight: 900;
    }

    .hero-proof dd {
        margin: 6px 0 0;
        color: var(--text-body);
        font-size: 0.86rem;
        font-weight: 700;
        line-height: 1.5;
        word-break: keep-all;
    }

    .hero-visual {
        position: relative;
        min-height: 620px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hero-main-card {
        position: relative;
        width: min(520px, 100%);
        padding: 14px;
        border: 1px solid rgba(13, 27, 42, 0.08);
        border-radius: 34px;
        background: rgba(255, 255, 255, 0.82);
        box-shadow: 0 32px 90px rgba(13, 27, 42, 0.16);
        backdrop-filter: blur(16px);
    }

    .hero-main-image {
        width: 100%;
        height: 520px;
        object-fit: cover;
        border-radius: 24px;
    }

    .hero-main-caption {
        position: absolute;
        right: 28px;
        bottom: 28px;
        left: 28px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 16px 18px;
        border-radius: 20px;
        background: rgba(13, 27, 42, 0.88);
        color: #fff;
        backdrop-filter: blur(12px);
    }

    .hero-main-caption span {
        color: var(--color-gold);
        font-size: 0.78rem;
        font-weight: 900;
        text-transform: uppercase;
    }

    .hero-main-caption strong {
        font-size: 0.98rem;
        word-break: keep-all;
    }

    .hero-float-card {
        position: absolute;
        width: 196px;
        padding: 10px;
        border: 1px solid rgba(13, 27, 42, 0.08);
        border-radius: 24px;
        background: #fff;
        box-shadow: 0 24px 70px rgba(13, 27, 42, 0.16);
    }

    .hero-float-card img {
        width: 100%;
        height: 124px;
        object-fit: cover;
        border-radius: 16px;
    }

    .hero-float-card span {
        display: block;
        margin-top: 10px;
        color: var(--color-navy);
        font-size: 0.8rem;
        font-weight: 900;
    }

    .hero-float-top {
        top: 42px;
        left: -18px;
        transform: rotate(-3deg);
    }

    .hero-float-bottom {
        right: -14px;
        bottom: 36px;
        transform: rotate(3deg);
    }

    @keyframes heroFadeUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes heroShine {
        0%,
        100% {
            opacity: 0.18;
            transform: skewX(-18deg) translateX(-26%);
        }
        50% {
            opacity: 0.58;
            transform: skewX(-18deg) translateX(28%);
        }
    }

    @media (max-width: 1024px) {
        .hero-section {
            min-height: auto;
            padding-top: 68px;
        }

        .hero-grid {
            grid-template-columns: 1fr;
        }

        .hero-visual {
            min-height: 540px;
        }
    }

    @media (max-width: 768px) {
        .hero-section {
            padding: 52px 0 44px;
        }

        .hero-proof {
            grid-template-columns: 1fr;
            margin-top: 28px;
        }

        .hero-visual {
            min-height: 420px;
        }

        .hero-main-card {
            width: 90%;
            border-radius: 26px;
        }

        .hero-main-image {
            height: 340px;
            border-radius: 18px;
        }

        .hero-main-caption {
            position: static;
            margin-top: 10px;
            border-radius: 16px;
            flex-direction: column;
            align-items: flex-start;
        }

        .hero-float-card {
            width: 138px;
        }

        .hero-float-card img {
            height: 86px;
        }

        .hero-float-top {
            top: 0;
            left: 0;
        }

        .hero-float-bottom {
            right: 0;
            bottom: 0;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .hero-shine,
        .hero-kicker,
        .hero-title,
        .hero-fade-up {
            animation: none;
            opacity: 1;
            transform: none;
        }
    }
</style>
