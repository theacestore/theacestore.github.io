---
const sampleFormUrl = "https://naver.me/GqfJUJaH";
const kakaoUrl = "https://open.kakao.com/o/sx6KEqpi";
const base = import.meta.env.BASE_URL;
---

<section class="hero-section">
    <div class="container hero-grid">
        <div class="hero-copy">
            <p class="eyebrow">Advanced Industrial Solutions</p>
            <h1>전문가의 기술로 완성하는 하이엔드 브랜드 솔루션</h1>
            <p class="hero-lead">
                독일 CAB사의 정밀 자동 부착 시스템부터 프리미엄 심리스 웰딩 로고까지, 브랜드 생산 현장에 필요한 고난도 라벨링과 부자재 솔루션을 설계합니다.
            </p>
            <div class="hero-actions">
                <a href={sampleFormUrl} target="_blank" rel="noopener" class="button button-primary">프로젝트 상담</a>
                <a href={kakaoUrl} target="_blank" rel="noopener" class="button button-secondary">카카오톡 문의</a>
                <a href={`${base}#products`} class="button button-secondary">솔루션 보기</a>
            </div>
            <dl class="hero-proof">
                <div>
                    <dt>CAB</dt>
                    <dd>자동 부착 시스템</dd>
                </div>
                <div>
                    <dt>Welding</dt>
                    <dd>심리스 PU 로고</dd>
                </div>
                <div>
                    <dt>B2B</dt>
                    <dd>생산형 프로젝트 대응</dd>
                </div>
            </dl>
        </div>

        <div class="hero-visual" aria-label="CAB 자동 부착 시스템과 심리스 웰딩 포트폴리오">
            <img src={`${base}images/cab_hermes_q.jpg`} alt="독일 CAB 자동 부착 시스템" class="hero-main-image" />
            <img src={`${base}images/welding_adidas.jpg`} alt="아디다스 심리스 웰딩 PU 로고" class="floating-card floating-card-top" />
            <img src={`${base}images/rapido_wellding.jpeg`} alt="라피도 심리스 웰딩 로고" class="floating-card floating-card-bottom" />
        </div>
    </div>
</section>

<style>
    .hero-section {
        padding: calc(var(--space-xl) + 24px) 0 var(--space-xl);
        overflow: hidden;
    }

    .hero-grid {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: var(--space-xl);
        align-items: center;
        min-height: 720px;
    }

    .hero-copy {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .hero-copy h1 {
        max-width: 780px;
        margin: var(--space-md) 0 0;
        color: var(--text-heading);
        font-size: 5.4rem;
        font-weight: 900;
        line-height: 1.02;
        letter-spacing: 0;
        word-break: keep-all;
    }

    .hero-lead {
        max-width: 620px;
        margin: var(--space-lg) 0 0;
        color: var(--text-body);
        font-size: 1.12rem;
        word-break: keep-all;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-md);
        margin-top: var(--space-lg);
    }

    .hero-proof {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: var(--space-md);
        width: 100%;
        max-width: 680px;
        margin: var(--space-xl) 0 0;
        padding: 0;
    }

    .hero-proof div {
        padding: var(--space-md);
        border: 1px solid rgba(0, 0, 0, 0.03);
        border-radius: var(--radius-md);
        background: rgba(255, 255, 255, 0.72);
        box-shadow: var(--shadow-soft);
    }

    .hero-proof dt {
        color: var(--text-heading);
        font-size: 1.08rem;
        font-weight: 900;
    }

    .hero-proof dd {
        margin: 4px 0 0;
        color: var(--text-body);
        font-size: 0.86rem;
        font-weight: 700;
    }

    .hero-visual {
        position: relative;
        min-height: 620px;
        display: flex;
        align-items: center;
        justify-content: center;
        isolation: isolate;
    }

    .hero-main-image {
        width: min(560px, 96%);
        height: 540px;
        object-fit: cover;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-soft);
        transform: translateX(16px) rotate(-1.5deg);
    }

    .floating-card {
        position: absolute;
        width: 220px;
        height: 154px;
        object-fit: cover;
        border: 8px solid var(--color-surface);
        border-radius: var(--radius-lg);
        background: var(--color-surface);
        box-shadow: var(--shadow-soft);
    }

    .floating-card-top {
        top: 36px;
        left: -16px;
        transform: rotate(4deg);
    }

    .floating-card-bottom {
        right: -12px;
        bottom: 48px;
        transform: rotate(-4deg);
    }

    @media (max-width: 1024px) {
        .hero-grid {
            grid-template-columns: 1fr;
            min-height: auto;
        }

        .hero-copy h1 {
            font-size: 4.4rem;
        }
    }

    @media (max-width: 768px) {
        .hero-section {
            padding: var(--space-xl) 0;
        }

        .hero-copy h1 {
            font-size: 3.1rem;
        }

        .hero-proof {
            grid-template-columns: 1fr;
            margin-top: var(--space-lg);
        }

        .hero-visual {
            min-height: 390px;
        }

        .hero-main-image {
            width: 88%;
            height: 330px;
            transform: rotate(-1.5deg);
        }

        .floating-card {
            width: 136px;
            height: 98px;
            border-width: 6px;
        }

        .floating-card-top {
            top: 8px;
            left: 0;
        }

        .floating-card-bottom {
            right: 0;
            bottom: 8px;
        }
    }
</style>
