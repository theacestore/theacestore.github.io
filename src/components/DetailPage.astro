---
interface DetailItem {
    label: string;
    value: string;
}

interface GalleryItem {
    title: string;
    image: string;
    alt: string;
}

interface Props {
    eyebrow: string;
    title: string;
    lead: string;
    image: string;
    points: string[];
    specs: DetailItem[];
    gallery?: GalleryItem[];
}

const { eyebrow, title, lead, image, points, specs, gallery = [] } = Astro.props;
---

<section class="detail-hero container">
    <div>
        <p class="eyebrow">{eyebrow}</p>
        <h1>{title}</h1>
        <p>{lead}</p>
    </div>
    <img src={image} alt={`${title} 제작 샘플`} />
</section>

{
    gallery.length > 0 && (
        <section class="detail-gallery container">
            <div class="gallery-heading">
                <p class="eyebrow">Portfolio</p>
                <h2>적용 사례</h2>
            </div>
            <div class="gallery-grid">
                {gallery.map((item) => (
                    <figure>
                        <img src={item.image} alt={item.alt} loading="lazy" />
                        <figcaption>{item.title}</figcaption>
                    </figure>
                ))}
            </div>
        </section>
    )
}

<section class="detail-grid container">
    <article>
        <h2>추천 포인트</h2>
        <ul>
            {points.map((point) => <li>{point}</li>)}
        </ul>
    </article>
    <article>
        <h2>기본 사양</h2>
        <dl>
            {specs.map((spec) => (
                <div>
                    <dt>{spec.label}</dt>
                    <dd>{spec.value}</dd>
                </div>
            ))}
        </dl>
    </article>
</section>

<style>
    .detail-hero {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-xl);
        align-items: center;
        padding: var(--space-xl) 0;
    }

    h1 {
        margin: var(--space-md) 0 0;
        color: var(--text-heading);
        font-size: 4rem;
        font-weight: 900;
        line-height: 1.05;
        letter-spacing: 0;
        word-break: keep-all;
    }

    .detail-hero p:not(.eyebrow) {
        max-width: 560px;
        margin-top: var(--space-lg);
        color: var(--text-body);
        font-size: 1.08rem;
        word-break: keep-all;
    }

    .detail-hero img {
        width: 100%;
        max-height: 440px;
        object-fit: contain;
        border-radius: var(--radius-lg);
        background: var(--color-surface);
        box-shadow: var(--shadow-soft);
    }

    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-lg);
    }

    .detail-gallery {
        margin-bottom: var(--space-lg);
    }

    .gallery-heading {
        margin-bottom: var(--space-md);
    }

    .gallery-heading h2 {
        margin-bottom: 0;
        font-size: 2rem;
    }

    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-md);
    }

    figure {
        margin: 0;
        padding: var(--space-md);
        border-radius: var(--radius-lg);
        background: var(--color-surface);
        box-shadow: var(--shadow-soft);
        transition: var(--transition-premium);
    }

    figure:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-hover);
    }

    figure img {
        width: 100%;
        height: 260px;
        object-fit: cover;
        border-radius: var(--radius-md);
    }

    figcaption {
        margin-top: var(--space-md);
        color: var(--text-heading);
        font-weight: 900;
    }

    article {
        padding: var(--space-lg);
        border-radius: var(--radius-lg);
        background: var(--color-surface);
        box-shadow: var(--shadow-soft);
    }

    h2 {
        margin: 0 0 var(--space-md);
        color: var(--text-heading);
        font-size: 1.5rem;
        font-weight: 900;
    }

    ul {
        margin: 0;
        padding-left: 20px;
    }

    li,
    dd {
        color: var(--text-body);
    }

    dl {
        margin: 0;
    }

    dl div {
        display: grid;
        grid-template-columns: 120px 1fr;
        gap: var(--space-md);
        padding: 12px 0;
        border-top: 1px solid rgba(0, 0, 0, 0.03);
    }

    dt {
        color: var(--text-heading);
        font-weight: 900;
    }

    dd {
        margin: 0;
    }

    @media (max-width: 768px) {
        .detail-hero,
        .detail-grid,
        .gallery-grid {
            grid-template-columns: 1fr;
        }

        h1 {
            font-size: 2.7rem;
        }
    }
</style>
