---
import ProductCard from "./ProductCard.astro";

const base = import.meta.env.BASE_URL;

const products = [
    {
        title: "자동 부착 라벨 시스템",
        eyebrow: "German CAB Automation",
        desc: "독일 CAB 장비 기반의 정밀 부착 공정으로 반복 생산 라인의 편차를 줄이고 안정적인 라벨 품질을 만듭니다.",
        image: `${base}images/cab_hermes_q.jpg`,
        featured: true,
    },
    {
        title: "심리스 웰딩 PU 로고",
        eyebrow: "Seamless Welding",
        desc: "봉제선 없이 매끈하게 접착되는 프리미엄 PU 로고 사양으로 의류, 스포츠웨어, 굿즈에 적합합니다.",
        image: `${base}images/welding_adidas.jpg`,
        href: `${base}details/seamless-welding/`,
        featured: true,
    },
    {
        title: "인쇄 라벨",
        eyebrow: "Printed Label",
        desc: "브랜드 로고, 원산지, 케어 정보, 보안 홀로그램까지 목적에 맞춰 정교하게 구현합니다.",
        image: `${base}images/hologram_label.jpg`,
        href: `${base}details/print-label/`,
    },
    {
        title: "패키지 부자재",
        eyebrow: "Package Materials",
        desc: "카드, 행택, 패키지 스티커 등 브랜드 접점에 필요한 부자재를 일관된 톤으로 제작합니다.",
        image: `${base}images/dencity_customer_card.jpg`,
        href: `${base}details/package-materials/`,
    },
    {
        title: "롤 라벨 공급",
        eyebrow: "Roll Label System",
        desc: "바코드용 blank 라벨과 감열 라벨을 규격, 권취 방향, 반복 발주 조건에 맞춰 공급합니다.",
        image: `${base}images/barcode_roll_label.jpeg`,
        href: `${base}details/barcode-label/`,
    },
    {
        title: "정밀 다이컷",
        eyebrow: "Precision Die-cut",
        desc: "포론, 보호필름, 기능성 부자재를 제품 형상에 맞춰 안정적인 치수로 가공합니다.",
        image: `${base}images/spigen_case_poro.jpeg`,
        href: `${base}details/poron-diecut/`,
    },
];
---

<section id="products" class="product-section">
    <div class="container">
        <div class="section-heading reveal">
            <p class="eyebrow">Industrial Portfolio</p>
            <h2>라벨부터 기능성 부자재까지, 생산 현장에 바로 연결되는 제품군</h2>
            <p>
                Uizard식 카드형 구성의 명료함은 살리고, 실제 제조 포트폴리오가 먼저 보이도록
                제품 이미지와 사양 중심으로 정리했습니다.
            </p>
        </div>

        <div class="bento-grid">
            {products.map((product) => (
                <ProductCard {...product} />
            ))}
        </div>
    </div>
</section>

<style>
    .product-section {
        padding: var(--space-xl) 0 calc(var(--space-xl) + var(--space-lg));
        background:
            radial-gradient(circle at 8% 0%, rgba(217, 83, 15, 0.1), transparent 26%),
            linear-gradient(180deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.74));
    }

    .section-heading {
        max-width: 900px;
        margin-bottom: 30px;
    }

    .bento-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-auto-rows: minmax(300px, auto);
        gap: 18px;
    }

    @media (max-width: 1024px) {
        .bento-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .bento-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
