---
import ProductCard from "./ProductCard.astro";

const base = import.meta.env.BASE_URL;

const products = [
    {
        title: "CAB 자동 부착 시스템",
        eyebrow: "German CAB Automation",
        desc: "정밀 라벨 공급과 자동 부착 공정을 기반으로 반복 생산 라인의 품질 편차를 줄입니다.",
        image: `${base}images/cab_hermes_q.jpg`,
        featured: true,
    },
    {
        title: "심리스 웰딩 PU 로고",
        eyebrow: "Seamless Welding",
        desc: "봉제선 없이 매끄럽게 접착되는 프리미엄 PU 로고 솔루션으로 고급 의류와 스포츠웨어에 적합합니다.",
        image: `${base}images/welding_adidas.jpg`,
        href: `${base}details/seamless-welding/`,
        featured: true,
    },
    {
        title: "인쇄용 라벨",
        eyebrow: "Printed Label",
        desc: "홀로그램, 금박, 기능성 소재까지 브랜드 아이덴티티를 정교하게 구현합니다.",
        image: `${base}images/hologram_label.jpg`,
        href: `${base}details/print-label/`,
    },
    {
        title: "패키지 부자재",
        eyebrow: "Package Materials",
        desc: "카드, 단상자, 포장 스티커를 브랜드 톤에 맞춰 설계합니다.",
        image: `${base}images/dencity_customer_card.jpg`,
        href: `${base}details/package-materials/`,
    },
    {
        title: "롤 라벨 솔루션",
        eyebrow: "Roll Label System",
        desc: "바코드용 Blank 라벨과 감열 라벨을 프린터, 권취, 반복 발주 조건에 맞춰 공급합니다.",
        image: `${base}images/barcode_roll_label.jpeg`,
        href: `${base}details/barcode-label/`,
    },
    {
        title: "정밀 다이컷",
        eyebrow: "Precision Die-cut",
        desc: "포론, 보호필름, 기능성 부자재를 제품 형상에 맞춰 안정적으로 가공합니다.",
        image: `${base}images/spigen_case_poro.jpeg`,
        href: `${base}details/poron-diecut/`,
    },
];
---

<section id="products" class="product-section">
    <div class="container">
        <div class="section-heading reveal">
            <p class="eyebrow">Industrial Portfolio</p>
            <h2>자동화 라벨링부터 심리스 웰딩까지, 생산 현장에 바로 연결되는 솔루션</h2>
        </div>

        <div class="bento-grid">
            {products.map((product) => (
                <ProductCard {...product} />
            ))}
        </div>
    </div>
</section>

<style>
    .product-section {
        padding: var(--space-xl) 0 calc(var(--space-xl) + var(--space-lg));
    }

    .section-heading {
        max-width: 900px;
        margin-bottom: var(--space-lg);
    }

    .section-heading h2 {
        margin: var(--space-sm) 0 0;
        color: var(--text-heading);
        font-size: 3.35rem;
        font-weight: 900;
        line-height: 1.08;
        letter-spacing: 0;
        word-break: keep-all;
    }

    .bento-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-auto-rows: minmax(300px, auto);
        gap: var(--space-md);
    }

    @media (max-width: 1024px) {
        .bento-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .section-heading h2 {
            font-size: 2.9rem;
        }
    }

    @media (max-width: 768px) {
        .section-heading h2 {
            font-size: 2.2rem;
        }

        .bento-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
