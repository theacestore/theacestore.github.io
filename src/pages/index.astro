---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ProductBento from "../components/ProductBento.astro";

const sampleFormUrl = "https://naver.me/GqfJUJaH";
const kakaoUrl = "https://open.kakao.com/o/sx6KEqpi";

const trustItems = [
    {
        title: "제조 사양 정리",
        desc: "소재, 점착, 규격, 권취 방향, 후가공 조건을 실제 생산 가능한 기준으로 빠르게 정리합니다.",
    },
    {
        title: "샘플 기반 검증",
        desc: "실물 샘플로 색상, 접착력, 두께, 마감감을 확인한 뒤 양산 편차를 줄입니다.",
    },
    {
        title: "반복 발주 대응",
        desc: "B2B 고객의 주기적 생산 일정에 맞춰 품질 기준과 납품 흐름을 유지합니다.",
    },
    {
        title: "브랜드 완성도",
        desc: "라벨 하나도 제품 경험의 일부로 보고, 산업적 신뢰감과 브랜드 톤을 함께 맞춥니다.",
    },
];

const processSteps = [
    ["01", "상담", "제품 사진, 도면, 수량, 사용 환경을 확인합니다."],
    ["02", "사양 설계", "소재와 인쇄, 접착, 가공 방식을 제안합니다."],
    ["03", "샘플 확인", "실물 샘플로 색상과 마감 품질을 검증합니다."],
    ["04", "양산 진행", "확정 사양 기준으로 생산과 품질 체크를 진행합니다."],
    ["05", "납품 관리", "반복 발주와 추가 사양 변경까지 이어서 관리합니다."],
];
---

<BaseLayout>
    <Hero />
    <ProductBento />

    <section class="process-section">
        <div class="container">
            <div class="section-heading section-heading-center reveal">
                <p class="eyebrow">Process</p>
                <h2>샘플에서 양산 납품까지, 제조 흐름을 투명하게 관리합니다</h2>
                <p>처음 문의하는 고객도 필요한 정보만 준비하면 사양 확정까지 빠르게 이동할 수 있습니다.</p>
            </div>
            <div class="process-grid">
                {processSteps.map(([number, step, desc]) => (
                    <article class="process-card reveal">
                        <span>{number}</span>
                        <h3>{step}</h3>
                        <p>{desc}</p>
                    </article>
                ))}
            </div>
        </div>
    </section>

    <section class="trust-section section-dark">
        <div class="container trust-grid">
            <div class="section-heading reveal">
                <p class="eyebrow">Manufacturing Trust</p>
                <h2>가벼운 SaaS 감성보다, 제조업 고객이 신뢰할 수 있는 근거를 먼저 보여줍니다</h2>
                <p>
                    레이블랩은 제품 기획 단계의 아이디어를 실제 생산 가능한 사양으로 바꾸고,
                    반복 납품에 필요한 품질 기준을 함께 쌓아갑니다.
                </p>
            </div>
            <div class="trust-list">
                {trustItems.map((item) => (
                    <article class="trust-card reveal">
                        <span aria-hidden="true"></span>
                        <h3>{item.title}</h3>
                        <p>{item.desc}</p>
                    </article>
                ))}
            </div>
        </div>
    </section>

    <section class="landing-cta-section">
        <div class="container">
            <div class="landing-cta reveal">
                <p class="eyebrow">Start Project</p>
                <h2>라벨, 패키지 부자재, 기능성 소재 제작을 지금 바로 상담하세요</h2>
                <p>
                    샘플 사진이나 도면, 예상 수량만 있어도 시작할 수 있습니다.
                    제조 가능한 방식과 견적 방향을 빠르게 안내드립니다.
                </p>
                <div class="cta-actions">
                    <a href={sampleFormUrl} target="_blank" rel="noopener" class="button button-primary">샘플 신청</a>
                    <a href={kakaoUrl} target="_blank" rel="noopener" class="button button-secondary">카카오톡 문의</a>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
