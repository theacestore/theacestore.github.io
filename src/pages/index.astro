---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ProductBento from "../components/ProductBento.astro";

const sampleFormUrl = "https://naver.me/GqfJUJaH";
const kakaoUrl = "https://open.kakao.com/o/sx6KEqpi";

const trustItems = ["소재 상담", "샘플 제작", "생산 사양 정리", "납품 대응"];
const processSteps = ["상담", "샘플 확인", "사양 확정", "제작", "납품"];
---

<BaseLayout>
    <Hero />
    <ProductBento />
    <section class="trust-section section-dark">
        <div class="container trust-grid">
            <div class="section-heading reveal">
                <p class="eyebrow">Manufacturing Trust</p>
                <h2>작은 브랜드도 대기업 납품 수준으로</h2>
                <p>
                    라벨랩은 제품 기획 단계의 소재 상담부터 샘플, 생산 사양, 납품 대응까지 제조 현장에서 바로 쓰일 수 있는 기준으로 정리합니다.
                </p>
            </div>
            <div class="trust-list">
                {trustItems.map((item) => (
                    <article class="trust-card reveal">
                        <span aria-hidden="true"></span>
                        <h3>{item}</h3>
                        <p>브랜드 상황과 생산 일정에 맞춰 필요한 정보를 빠르게 정리하고 실행 가능한 방향으로 제안합니다.</p>
                    </article>
                ))}
            </div>
        </div>
    </section>

    <section class="process-section">
        <div class="container">
            <div class="section-heading section-heading-center reveal">
                <p class="eyebrow">Process</p>
                <h2>샘플에서 양산 납품까지 흐름을 분명하게 관리합니다</h2>
            </div>
            <div class="process-grid">
                {processSteps.map((step, index) => (
                    <article class="process-card reveal">
                        <span>{String(index + 1).padStart(2, "0")}</span>
                        <h3>{step}</h3>
                    </article>
                ))}
            </div>
        </div>
    </section>

    <section class="landing-cta-section">
        <div class="container">
            <div class="landing-cta reveal">
                <p class="eyebrow">Start Project</p>
                <h2>샘플부터 납품까지, 지금 바로 상담하세요</h2>
                <div class="cta-actions">
                    <a href={sampleFormUrl} target="_blank" rel="noopener" class="button button-primary">샘플 신청</a>
                    <a href={kakaoUrl} target="_blank" rel="noopener" class="button button-secondary">카카오톡 문의</a>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
